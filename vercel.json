{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": ""
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.github.io https://*.vercel.app http://localhost:* http://127.0.0.1:*;"
        }
      ]
    }
  ]
}
