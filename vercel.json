{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": ""
        },
        {
          "key": "Test",
          "value": "111"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://*.github.io https://*.vercel.app;"
        }
      ]
    }
  ]
}
